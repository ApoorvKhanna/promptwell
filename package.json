{
  "name": "promptwell",
  "version": "0.1.3",
  "description": "Prompt optimizer and coach for Claude Fable 5 — stop burning tokens on bad prompts",
  "type": "module",
  "bin": {
    "promptwell": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "SKILL.md",
    "welcome.html"
  ],
  "keywords": [
    "mcp",
    "fable5",
    "claude",
    "prompt-optimization",
    "ai"
  ],
  "license": "MIT",
  "author": "Apoorv Khanna",
  "repository": {
    "type": "git",
    "url": "https://github.com/ApoorvKhanna/promptwell.git"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": "./dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^7.5.0",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
